# Copy to .env and customize for your environment.
# All values shown are the defaults used when unset.

# PostgreSQL credentials (docker-compose.yml). POSTGRES_PASSWORD is required — compose fails fast if
# it is unset rather than falling back to a weak default. Use a strong, unique value.
POSTGRES_USER=yasuki
POSTGRES_PASSWORD=yasuki
POSTGRES_DB=yasuki

# Optional least-privilege read-only DB role for the API runtime. Leave POSTGRES_RO_PASSWORD empty to
# run the API as the owner role. Set it to have db-init provision a SELECT-only role, then switch the
# api service's YASUKI_DATABASE_URL to the commented read-only DSN in docker-compose.yml.
POSTGRES_RO_USER=yasuki_ro
# POSTGRES_RO_PASSWORD=

# API server
# Set to "production" to disable /docs and /redoc
ENVIRONMENT=development

# Override for CDN, e.g. https://pub-xxx.r2.dev
IMAGE_BASE_URL=/images

# Comma-separated allowed origins
CORS_ORIGINS=http://localhost:5173,http://localhost:3000,http://localhost:8080

# Hosts/CIDRs whose X-Forwarded-For header uvicorn will trust (used to derive the real client IP for
# rate limiting). Defaults to 127.0.0.1 — set this to your edge proxy / load-balancer IP or subnet
# in production. NEVER set it to "*", which lets any client spoof their IP and bypass rate limits.
TRUSTED_PROXY_IPS=127.0.0.1

# Path to a CA bundle for the database server's certificate. When set, connections to non-private DB
# hosts use sslmode=verify-full (cert + hostname verified) instead of the unauthenticated
# sslmode=require fallback. Point this at your managed-Postgres provider's CA file.
# YASUKI_DB_SSL_ROOT_CERT=/etc/ssl/certs/db-ca.pem
