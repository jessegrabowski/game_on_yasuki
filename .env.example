# Copy to .env and customize for your environment.
# All values shown are the defaults used when unset.

# PostgreSQL credentials (docker-compose.yml). POSTGRES_PASSWORD is required — compose fails fast if
# it is unset rather than falling back to a weak default. Use a strong, unique value.
POSTGRES_USER=yasuki
POSTGRES_PASSWORD=yasuki
POSTGRES_DB=yasuki

# Optional least-privilege read-only DB role for the API runtime. Leave POSTGRES_RO_PASSWORD empty to
# run the API as the owner role. Set it to have db-init provision a SELECT-only role, then switch the
# api service's YASUKI_DATABASE_URL to the commented read-only DSN in docker-compose.yml.
POSTGRES_RO_USER=yasuki_ro
# POSTGRES_RO_PASSWORD=

# API server
# Set to "production" to disable /docs and /redoc
ENVIRONMENT=development

# Shared password gating the work-in-progress online-play surface (the unlinked /top-secret.html
# page plus the rooms API and WebSocket handshake) until launch. Unset = the surface is disabled
# (fails closed). Username at the browser prompt is "yasuki"; share the password out-of-band.
# WIP_PLAY_PASSWORD=

# Override for CDN, e.g. https://pub-xxx.r2.dev
IMAGE_BASE_URL=/images

# Comma-separated allowed origins. Governs both REST CORS and the WebSocket handshake origin check,
# so in production the deployed site's own origin (e.g. https://play.example) must be listed here or
# browser WebSocket connections to the play room are rejected.
CORS_ORIGINS=http://localhost:5173,http://localhost:3000,http://localhost:8080

# Hosts/CIDRs whose X-Forwarded-For header uvicorn will trust (used to derive the real client IP for
# rate limiting). Defaults to 127.0.0.1 — set this to your edge proxy / load-balancer IP or subnet
# in production. NEVER set it to "*", which lets any client spoof their IP and bypass rate limits.
TRUSTED_PROXY_IPS=127.0.0.1

# Path to a CA bundle for the database server's certificate. When set, connections to non-private DB
# hosts use sslmode=verify-full (cert + hostname verified) instead of the unauthenticated
# sslmode=require fallback. Point this at your managed-Postgres provider's CA file.
# YASUKI_DB_SSL_ROOT_CERT=/etc/ssl/certs/db-ca.pem

# ─── Accounts: login, saved decks, online play (PR 11+) ───
# Without the three GOOGLE_* values set, /auth/* returns 503 and these features are simply off; the
# public card-search and deck-builder surfaces work regardless.

# DSN of the SEPARATE accounts Postgres (users, sessions, decks, banlist), kept isolated from the
# card DB so a card reseed can never reach user data. Unset → defaults to a local yasuki_accounts
# database (postgresql://localhost/yasuki_accounts; create it once with `createdb yasuki_accounts`).
# On Railway: add a second Postgres service and set this to its ${{Postgres-accounts.DATABASE_URL}}.
# The app applies the schema on startup (idempotent, never drops); an unreachable accounts DB is
# logged and skipped, leaving the public surface up.
# YASUKI_ACCOUNTS_DATABASE_URL=postgresql://localhost/yasuki_accounts

# Secret keying the email/sub blind index — emails are NEVER stored in the clear, only as
# HMAC-SHA256(value, pepper). LOAD-BEARING AND EFFECTIVELY UN-ROTATABLE: changing it re-hashes every
# email and sub differently, orphaning duplicate-account detection and every banlist tombstone.
# Generate once (`openssl rand -hex 32`), store beside the DB credentials, never change.
# YASUKI_EMAIL_HMAC_PEPPER=

# Google OAuth web-client credentials and the registered callback. The redirect URI must match the
# Google Cloud console entry EXACTLY, and be your deployed origin + /auth/callback.
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_REDIRECT_URI=https://play.example/auth/callback

# Local-only shortcut: GET /auth/dev-login mints a session without Google (set to 1 for local dev).
# Refused with 404 whenever ENVIRONMENT=production, so it can never be a deployed backdoor. Leave
# unset in any shared environment.
# YASUKI_DEV_LOGIN=

# New accounts start unapproved and an admin approves them in Settings → Admin. To get an email when
# someone signs up, set the recipient and an SMTP server (any provider; Gmail needs an app password).
# Unset = no email is sent (sign-up still works and the account still shows up pending in the admin
# dashboard). YASUKI_SMTP_HOST + YASUKI_ADMIN_EMAIL are the minimum; port defaults to 587 (STARTTLS),
# use 465 for implicit SSL.
# YASUKI_ADMIN_EMAIL=you@example.com
# YASUKI_SMTP_HOST=smtp.gmail.com
# YASUKI_SMTP_PORT=587
# YASUKI_SMTP_USER=you@gmail.com
# YASUKI_SMTP_PASSWORD=your-app-password
# YASUKI_SMTP_FROM=you@gmail.com
